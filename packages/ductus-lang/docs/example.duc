node Driver:
  out: Drives
  attr expertise: i32 = 5
  derived report: string = "speed: {self.???.effective_speed}"

connection Drives:
  from: Driver
  to: Vehicle
  attr enhanced_handling: bool = false
  derived effective_speed: f32 = to.top_speed * (from.expertise as f32 / 10.0)

node Vehicle:
  in: Drives
  attr top_speed: i32 = 160


node Fetch:
  signal response: Option<HttpResponse>

recurrent foo: i32 = 1 |